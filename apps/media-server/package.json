{
  "name": "@feed/media-server",
  "version": "1.0.0",
  "description": "Self-hosted media server with metadata extraction",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@feed/shared": "workspace:*",
    "cors": "^2.8.6",
    "exif-reader": "^2.0.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.0",
    "file-type": "^22.0.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "nanoid": "^5.1.7",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22",
    "tsx": "^4.19.0",
    "typescript": "^6"
  }
}
